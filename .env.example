# Copy this file to .env and fill in real values before running docker-compose.

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tickettracker
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=tickettracker;Username=postgres;Password=postgres

# JWT (Secret must be a long, random value in real environments - never commit a real one)
Jwt__Secret=change-me-to-a-long-random-string-at-least-32-bytes
Jwt__Issuer=TicketTracker
Jwt__Audience=TicketTracker
Jwt__ExpiryMinutes=60

# SMTP
Smtp__Host=smtp.example.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromAddress=no-reply@example.com
Smtp__FromName=TicketTracker
Smtp__UseSsl=true

# App (used to build links sent in emails, e.g. email verification)
App__PublicUrl=http://localhost:8000

# Frontend (baked into the built JS bundle at image build time via a Docker build arg -
# must be reachable from the user's browser, not just from other containers, so this
# should stay as the host-published backend port, not the internal "backend" service name)
VITE_API_BASE_URL=http://localhost:8000
